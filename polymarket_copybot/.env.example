# Polymarket wallet credentials
PRIVATE_KEY=0x...
FUNDER_ADDRESS=0x...

# Polymarket CLOB API credentials (from https://polymarket.com/settings/api-keys)
API_KEY=...
API_SECRET=...
API_PASSPHRASE=...

# Anthropic API key (from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Target trader wallet address to copy
TARGET_WALLET=0x...

# Risk parameters
MAX_POSITION_USDC=50         # Maximum USDC per copied position
COPY_FRACTION=0.10           # Fraction of target's position size to copy (10%)
POLL_INTERVAL=30             # Seconds between polling cycles
MAX_ENTRY_AGE_MINUTES=10     # Ignore positions older than this many minutes
