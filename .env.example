# ── Required ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token

# NBA stats — BallDontLie (https://www.balldontlie.io/)
BALLDONTLIE_API_KEY=your_balldontlie_api_key

# Odds / lines — The Odds API (https://the-odds-api.com/)
ODDS_API_KEY=your_odds_api_key

# ── Optional ──────────────────────────────────────────────────────────────────
# Esports — Pandascore (https://pandascore.co/)  Free tier: 1000 req/hr
# Supports CS2, LoL, Valorant, Dota 2, and more
PANDASCORE_API_KEY=your_pandascore_api_key

# Discord guild ID for instant slash command sync during development
DISCORD_GUILD_ID=optional_guild_id_for_testing

# ── Free APIs (no key needed) ─────────────────────────────────────────────────
# NHL:    api-web.nhle.com       — official NHL API, no key required
# NFL:    site.api.espn.com      — ESPN unofficial API, no key required
# Soccer: site.api.espn.com      — ESPN soccer API, no key required
# Tennis: site.api.espn.com      — ESPN tennis API, no key required
